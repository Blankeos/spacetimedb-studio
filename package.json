{
  "name": "spacetimedb-studio",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "refs:clone": "bun scripts/fetch-references.ts clone",
    "refs:pull": "bun scripts/fetch-references.ts pull",
    "dev": "bun run --filter './apps/*' dev",
    "dev:studio": "bun run --filter './apps/studio' dev",
    "dev:cli": "bun run --filter './packages/cli' dev",
    "build": "bun run --filter './apps/*' build",
    "cli": "cd packages/cli && ./dist/spacetime-studio",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "changeset": "changeset",
    "readme:sync": "cp README.md packages/cli/README.md",
    "publish-ci": "bun run readme:sync && bun run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
